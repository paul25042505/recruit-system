                <div style={{display:"flex",alignItems:"center",gap:10}}>
                  <div style={{background:"#334155",borderRadius:8,padding:"5px 9px",fontSize:13,fontWeight:700,color:"#94a3b8",flexShrink:0}}>{t.seatNo}</div>
