                  <span style={{color:"#475569"}}>›</span>
                </div>
                {t.interviewNote&&<div style={{marginTop:8,fontSize:11,color:"#64748b",background:"#0f172a",borderRadius:6,padding:"5px 10px",borderLeft:"3px solid #334155"}}>{t.interviewNote.slice(0,60)}{t.interviewNote.length>60?"…":""}</div>}
              </div>
            );
          })}
          {list.length===0&&<div style={{textAlign:"center",color:"#475569",padding:40}}><div style={{fontSize:36,marginBottom:8}}>🔍</div>找不到符合條件的訓員</div>}
        </div>
      </div>
    );
  }

  // ══════════════════════════════════════════════════════════════════════════
  // TRAINEE DETAIL
  // ══════════════════════════════════════════════════════════════════════════
  if(view==="trainee"&&currentTrainee){
    const t=currentTrainee;
    const si=t.status?getStatus(t.status):null;
    const Field=({label,field,type="text",options,span2})=>(
      <div style={{marginBottom:12,gridColumn:span2?"span 2":"span 1"}}>
        <label style={S.lbl}>{label}</label>
        {options
          ?<select style={S.sel} value={t[field]||""} onChange={e=>updateTrainee(t.id,field,e.target.value)}><option value="">請選擇</option>{options.map(o=><option key={o}>{o}</option>)}</select>
          :type==="textarea"
            ?<textarea style={{...S.inp,minHeight:80,resize:"vertical"}} value={t[field]||""} onChange={e=>updateTrainee(t.id,field,e.target.value)}/>
            :<input style={S.inp} type={type} value={t[field]||""} onChange={e=>updateTrainee(t.id,field,e.target.value)}/>
        }
      </div>
    );
    return (
      <div style={S.app}><GFont/><Toast/>
        <div style={S.hdr}>
          <button style={{...S.btn("ghost","sm"),padding:"5px 8px"}} onClick={()=>setView("batch")}>←</button>
          <div>
            <div style={{fontSize:16,fontWeight:700,color:"#f8fafc"}}>{t.seatNo} · {t.name}</div>
            <div style={{fontSize:11,color:"#94a3b8"}}>{si?`${si.emoji} ${si.label}`:"尚未評估"}</div>
          </div>
        </div>
        <div style={{...S.sec,paddingBottom:160}}>
          <div style={S.card}>
            <div style={{fontSize:11,fontWeight:700,color:"#f59e0b",letterSpacing:"0.1em",marginBottom:12}}>▍ 基本資料</div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"0 10px"}}>
              <Field label="姓名" field="name"/><Field label="年齡" field="age" type="number"/>
              <Field label="居住地" field="city" options={CITIES}/><Field label="血型" field="bloodType" options={["A","B","O","AB"]}/>
              <Field label="學歷" field="education" options={EDUCATIONS}/><Field label="科系" field="department"/>
              <Field label="身高(cm)" field="height" type="number"/><Field label="體重(kg)" field="weight" type="number"/>
              <Field label="聯絡電話" field="phone" type="tel" span2/><Field label="入伍日期" field="entryDate" type="date" span2/>
            </div>
          </div>
          <div style={S.card}>
            <div style={{fontSize:11,fontWeight:700,color:"#f59e0b",letterSpacing:"0.1em",marginBottom:12}}>▍ 訪談紀錄</div>
            <Field label="訪談摘要" field="interviewNote" type="textarea" span2/>
            <Field label="招募員備注" field="recruiterNote" type="textarea" span2/>
          </div>
        </div>
        <div style={S.sBar}>
          <div style={{fontSize:11,color:"#64748b",marginBottom:8,fontWeight:600}}>意願評估</div>
          <div style={{display:"flex",gap:6,overflowX:"auto"}}>
            {(settings?.statusOptions||[]).map(s=>(
              <button key={s.id} onClick={()=>updateTrainee(t.id,"status",t.status===s.id?null:s.id)}
                style={{flexShrink:0,padding:"8px 12px",borderRadius:10,border:"none",cursor:"pointer",fontSize:12,fontWeight:700,
                  background:t.status===s.id?s.color:"#0f172a",color:t.status===s.id?"#fff":s.color,
                  outline:t.status===s.id?"none":`1px solid ${s.color}44`}}>
                {s.emoji} {s.label}
              </button>
            ))}
          </div>
        </div>
      </div>
    );
  }

  // ══════════════════════════════════════════════════════════════════════════
  // ADMIN PASSWORD
  // ══════════════════════════════════════════════════════════════════════════
  if(view==="adminPwd") return (
    <div style={{...S.app,...S.center}}><GFont/>
      <div style={{width:"100%",maxWidth:360}}>
        <div style={{textAlign:"center",marginBottom:28}}>
          <div style={{fontSize:44,marginBottom:10}}>🛡️</div>
          <div style={{fontSize:17,fontWeight:700,color:"#f8fafc"}}>管理員登入</div>
          <div style={{fontSize:12,color:"#64748b",marginTop:6}}>請輸入管理員密碼</div>
        </div>
        <input style={{...S.inp,textAlign:"center",fontSize:20,letterSpacing:"0.2em",marginBottom:10,padding:14}}
          type="password" placeholder="••••••" value={adminPwdInput}
          onChange={e=>{setAdminPwdInput(e.target.value);setAdminPwdError(false);}}
          onKeyDown={e=>e.key==="Enter"&&submitAdminPwd()} autoFocus/>
        {adminPwdError&&<div style={{textAlign:"center",color:"#ef4444",fontSize:13,marginBottom:10}}>密碼錯誤</div>}
        <button style={{...S.btn("primary"),width:"100%",padding:12}} onClick={submitAdminPwd}>進入後台</button>
        <button style={{...S.btn("ghost"),width:"100%",marginTop:8,padding:10}} onClick={()=>setView("home")}>← 返回</button>
      </div>
    </div>
  );

  // ══════════════════════════════════════════════════════════════════════════
  // ADMIN PANEL
  // ══════════════════════════════════════════════════════════════════════════
  if(view==="admin") return (
    <div style={S.app}><GFont/><Toast/>
      <div style={S.hdr}>
        <button style={{...S.btn("ghost","sm"),padding:"5px 8px"}} onClick={()=>setView("home")}>←</button>
        <div>
          <div style={{fontSize:16,fontWeight:700,color:"#f8fafc"}}>系統後台</div>
          <div style={{fontSize:11,color:"#94a3b8"}}>ADMIN PANEL</div>
        </div>
      </div>

      <div style={{display:"flex",borderBottom:"1px solid #334155",padding:"0 14px",overflowX:"auto"}}>
        {[["units","🏢 接訓單位"],["batches","📋 梯次密碼"],["status","🏷️ 意願選項"],["security","🔐 安全設定"]].map(([k,l])=>(
          <button key={k} onClick={()=>setAdminTab(k)}
            style={{...S.btn("ghost","sm"),borderRadius:0,padding:"12px 12px",flexShrink:0,
              borderBottom:adminTab===k?"2px solid #f59e0b":"2px solid transparent",
              color:adminTab===k?"#f59e0b":"#64748b"}}>{l}</button>
        ))}
      </div>

      <div style={S.sec}>

        {/* 接訓單位 */}
        {adminTab==="units"&&<>
          <div style={{fontSize:13,fontWeight:700,color:"#94a3b8",marginBottom:12}}>接訓單位管理</div>
          {(settings?.units||[]).map(u=>(
            <div key={u} style={{...S.card,padding:"12px 14px",display:"flex",alignItems:"center",justifyContent:"space-between"}}>
              <span style={{fontSize:14,fontWeight:600,color:"#f8fafc"}}>🏢 {u}</span>
              <button style={S.btn("danger","sm")} onClick={()=>removeUnit(u)}>刪除</button>
            </div>
          ))}
          <hr style={S.div}/>
          <div style={S.card}>
            <div style={{fontSize:13,fontWeight:700,color:"#f8fafc",marginBottom:12}}>新增單位</div>
            <div style={{display:"flex",gap:8}}>
              <input style={{...S.inp,flex:1}} placeholder="輸入單位名稱" value={newUnit} onChange={e=>setNewUnit(e.target.value)} onKeyDown={e=>e.key==="Enter"&&addUnit()}/>
              <button style={{...S.btn("primary","sm"),flexShrink:0}} onClick={addUnit}>新增</button>
            </div>
          </div>
        </>}

        {/* 梯次密碼 */}
        {adminTab==="batches"&&<>
          <div style={{fontSize:13,fontWeight:700,color:"#94a3b8",marginBottom:12}}>梯次密碼管理</div>
          {batches.map(b=>(
            <div key={b.id} style={S.card}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
                <div style={{fontSize:14,fontWeight:700,color:"#f8fafc"}}>{b.unit} · {b.battalion} · {b.sequence}</div>
                <button style={S.btn("danger","sm")} onClick={()=>removeBatch(b.id)}>刪除</button>
              </div>
              <label style={S.lbl}>專案密碼</label>
              <div style={{display:"flex",gap:8}}>
                <input style={S.inp} type={editPwdVisible[b.id]?"text":"password"} value={b.password}
                  onChange={e=>setBatches(p=>p.map(x=>x.id===b.id?{...x,password:e.target.value}:x))}/>
                <button style={{...S.btn("ghost","sm"),flexShrink:0}} onClick={()=>setEditPwdVisible(p=>({...p,[b.id]:!p[b.id]}))}>
                  {editPwdVisible[b.id]?"隱藏":"顯示"}
                </button>
                <button style={{...S.btn("primary","sm"),flexShrink:0}} onClick={()=>saveBatchPwd(b)}>儲存</button>
              </div>
            </div>
          ))}
        </>}

        {/* 意願選項 */}
        {adminTab==="status"&&<>
          <div style={{fontSize:13,fontWeight:700,color:"#94a3b8",marginBottom:12}}>意願評估選項</div>
          {(settings?.statusOptions||[]).map(s=>(
            <div key={s.id} style={{...S.card,padding:"12px 14px",display:"flex",alignItems:"center",gap:10}}>
              <div style={{fontSize:22,width:30}}>{s.emoji}</div>
              <div style={{flex:1}}>
                <div style={{fontSize:14,fontWeight:700,color:"#f8fafc"}}>{s.label}</div>
                <div style={{display:"flex",alignItems:"center",gap:5,marginTop:2}}>
                  <div style={{width:10,height:10,borderRadius:"50%",background:s.color}}/>
                  <span style={{fontSize:11,color:"#64748b"}}>{s.color}</span>
                </div>
              </div>
              <button style={S.btn("danger","sm")} onClick={()=>removeStatusOption(s.id)}>刪除</button>
            </div>
          ))}
          <hr style={S.div}/>
          <div style={S.card}>
            <div style={{fontSize:13,fontWeight:700,color:"#f8fafc",marginBottom:12}}>新增選項</div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 2fr 1fr",gap:8,marginBottom:10}}>
              <div><label style={S.lbl}>Emoji</label><input style={S.inp} placeholder="😊" value={newStatusItem.emoji} onChange={e=>setNewStatusItem(p=>({...p,emoji:e.target.value}))}/></div>
              <div><label style={S.lbl}>名稱</label><input style={S.inp} placeholder="觀察中" value={newStatusItem.label} onChange={e=>setNewStatusItem(p=>({...p,label:e.target.value}))}/></div>
              <div><label style={S.lbl}>顏色</label><input style={{...S.inp,padding:"6px 8px",cursor:"pointer"}} type="color" value={newStatusItem.color} onChange={e=>setNewStatusItem(p=>({...p,color:e.target.value}))}/></div>
            </div>
            <button style={{...S.btn("primary"),width:"100%"}} onClick={addStatusOption}>新增選項</button>
          </div>
        </>}

        {/* 安全設定 */}
        {adminTab==="security"&&<>
          <div style={{fontSize:13,fontWeight:700,color:"#94a3b8",marginBottom:12}}>安全設定</div>
          <div style={S.card}>
            <div style={{fontSize:13,fontWeight:700,color:"#f8fafc",marginBottom:12}}>更改管理員密碼</div>
            <label style={S.lbl}>新密碼</label>
            <input style={{...S.inp,marginBottom:10}} type="password" placeholder="輸入新密碼" value={newAdminPwd} onChange={e=>setNewAdminPwd(e.target.value)}/>
            <button style={{...S.btn("primary"),width:"100%"}} onClick={updateAdminPwd}>更新密碼</button>
          </div>
        </>}

      </div>
    </div>
  );

  return null;
}
