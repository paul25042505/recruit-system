            <div style={{display:"flex",gap:10}}>
              <button style={{...S.btn("ghost"),flex:1}} onClick={()=>setShowAddBatch(false)}>取消</button>
              <button style={{...S.btn("primary"),flex:1}} onClick={addBatch} disabled={saving}>{saving?"儲存中…":"新增"}</button>
            </div>
          </div>
        </div>
      )}
    </div>
  );

  // ══════════════════════════════════════════════════════════════════════════
  // BATCH PASSWORD
  // ══════════════════════════════════════════════════════════════════════════
  if(view==="batchPwd") return (
    <div style={{...S.app,...S.center}}><GFont/>
      <div style={{width:"100%",maxWidth:360}}>
        <div style={{textAlign:"center",marginBottom:28}}>
          <div style={{fontSize:44,marginBottom:10}}>🔒</div>
          <div style={{fontSize:17,fontWeight:700,color:"#f8fafc"}}>輸入專案密碼</div>
          <div style={{fontSize:12,color:"#64748b",marginTop:6}}>{currentBatch?.unit} · {currentBatch?.battalion} · {currentBatch?.sequence}</div>
        </div>
        <input style={{...S.inp,textAlign:"center",fontSize:20,letterSpacing:"0.2em",marginBottom:10,padding:14}}
          type="password" placeholder="••••••" value={batchPwdInput}
          onChange={e=>{setBatchPwdInput(e.target.value);setBatchPwdError(false);}}
          onKeyDown={e=>e.key==="Enter"&&submitBatchPwd()} autoFocus/>
        {batchPwdError&&<div style={{textAlign:"center",color:"#ef4444",fontSize:13,marginBottom:10}}>密碼錯誤，請重試</div>}
        <button style={{...S.btn("primary"),width:"100%",padding:12}} onClick={submitBatchPwd}>進入</button>
        <button style={{...S.btn("ghost"),width:"100%",marginTop:8,padding:10}} onClick={()=>setView("home")}>← 返回</button>
      </div>
    </div>
  );

  // ══════════════════════════════════════════════════════════════════════════
  // BATCH LIST
  // ══════════════════════════════════════════════════════════════════════════
  if(view==="batch"){
    const list=filteredTrainees();
    return (
      <div style={S.app}><GFont/><Toast/>
        <div style={S.hdr}>
          <button style={{...S.btn("ghost","sm"),padding:"5px 8px"}} onClick={()=>setView("home")}>←</button>
          <div>
            <div style={{fontSize:16,fontWeight:700,color:"#f8fafc"}}>{currentBatch?.unit} · {currentBatch?.sequence}</div>
            <div style={{fontSize:11,color:"#94a3b8"}}>{currentBatch?.battalion} · {list.length} 人</div>
          </div>
        </div>
        <div style={{padding:"12px 14px 0"}}>
          <input style={{...S.inp,marginBottom:8}} placeholder="🔍 搜尋姓名、座號、居住地…" value={searchQuery} onChange={e=>setSearchQuery(e.target.value)}/>
          <div style={{display:"flex",gap:6,overflowX:"auto",paddingBottom:8}}>
            <button style={{...S.btn(filterStatus==="all"?"primary":"ghost","sm"),flexShrink:0}} onClick={()=>setFilterStatus("all")}>全部</button>
            {(settings?.statusOptions||[]).map(s=>(
              <button key={s.id} style={{...S.btn(filterStatus===String(s.id)?"primary":"ghost","sm"),flexShrink:0,color:filterStatus===String(s.id)?"#fff":s.color}} onClick={()=>setFilterStatus(String(s.id))}>{s.emoji} {s.label}</button>
            ))}
          </div>
        </div>
        <div style={{...S.sec,paddingTop:8}}>
          {list.map(t=>{
            const si=t.status?getStatus(t.status):null;
