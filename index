  // ══════════════════════════════════════════════════════════════════════════
  if(view==="home") return (
    <div style={S.app}><GFont/><Toast/>
      <div style={S.hdr}>
        <div style={S.logo}>🎖️</div>
        <div>
          <div style={{fontSize:16,fontWeight:700,color:"#f8fafc",letterSpacing:"0.05em"}}>招募訓員管理系統</div>
          <div style={{fontSize:11,color:"#94a3b8",marginTop:1}}>RECRUITMENT MANAGEMENT SYSTEM</div>
        </div>
        <button style={{...S.btn("ghost","sm"),marginLeft:"auto"}} onClick={()=>{setView("adminPwd");setAdminPwdInput("");setAdminPwdError(false);}}>⚙️ 後台</button>
      </div>

      <div style={S.sec}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}>
          <div>
            <div style={{fontSize:17,fontWeight:700,color:"#f8fafc"}}>梯次列表</div>
            <div style={{fontSize:12,color:"#64748b",marginTop:2}}>共 {batches.length} 個梯次</div>
          </div>
          <button style={S.btn("primary","sm")} onClick={()=>setShowAddBatch(true)}>＋ 新增梯次</button>
        </div>

        {batches.map(batch=>{
          const st=batchStats(batch);
          const pct=st.total?Math.round(st.reviewed/st.total*100):0;
          return (
            <div key={batch.id} style={{...S.card,cursor:"pointer"}} onClick={()=>enterBatch(batch)}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start"}}>
                <div>
                  <div style={{fontSize:15,fontWeight:700,color:"#f8fafc",marginBottom:5}}>{batch.unit} · {batch.battalion} · {batch.sequence}</div>
                  <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
                    <span style={S.badge}>建立 {batch.createdAt}</span>
                    <span style={S.badge}>訓員 {st.total} 人</span>
                    <span style={S.tag("#22c55e")}>確簽 {st.confirmed} 人</span>
                  </div>
                </div>
                <span style={{color:"#475569",fontSize:20}}>›</span>
              </div>
              <div style={{marginTop:12}}>
                <div style={{display:"flex",justifyContent:"space-between",marginBottom:4}}>
                  <span style={{fontSize:11,color:"#64748b"}}>訪談進度</span>
                  <span style={{fontSize:11,color:"#94a3b8"}}>{st.reviewed}/{st.total}</span>
                </div>
                <div style={{height:4,background:"#334155",borderRadius:4,overflow:"hidden"}}>
                  <div style={{height:"100%",width:`${pct}%`,background:"linear-gradient(90deg,#f59e0b,#ef4444)",borderRadius:4}}/>
                </div>
              </div>
            </div>
          );
        })}
        {batches.length===0&&<div style={{textAlign:"center",color:"#475569",padding:40}}><div style={{fontSize:40,marginBottom:8}}>📋</div>尚無梯次</div>}
      </div>

      {showAddBatch&&(
        <div style={S.modal}>
          <div style={S.mBox}>
            <div style={{fontSize:16,fontWeight:700,marginBottom:18,color:"#f8fafc"}}>新增梯次</div>
            {[["接訓單位","unit",(settings?.units||[])],["營","battalion",BATTALIONS]].map(([lbl,key,opts])=>(
              <div key={key} style={{marginBottom:12}}>
                <label style={S.lbl}>{lbl}</label>
                <select style={S.sel} value={newBatch[key]} onChange={e=>setNewBatch(p=>({...p,[key]:e.target.value}))}>
                  <option value="">請選擇</option>{opts.map(o=><option key={o}>{o}</option>)}
