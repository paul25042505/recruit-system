            <div style={{marginBottom:12}}><label style={S.lbl}>梯次</label><input style={S.inp} placeholder="例：第1梯次" value={newBatch.sequence} onChange={e=>setNewBatch(p=>({...p,sequence:e.target.value}))}/></div>
